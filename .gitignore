# .gitignore — files git should NEVER track or upload to GitHub

# dependencies — huge folder of installed packages; rebuilt anytime with `npm install`
/node_modules

# Next.js build output — generated files, rebuilt anytime with `npm run build`
/.next
/out

# environment variables — contains your SECRET Supabase keys. NEVER push this to GitHub.
.env.local
.env*.local

# misc system/editor junk
.DS_Store
*.log
