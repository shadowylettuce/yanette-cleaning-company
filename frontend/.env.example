# Supabase connection — copy this file to .env.local and replace the placeholders.
# Get values from Supabase → Project Settings → API (Project URL + anon/public key).
# NEVER commit .env.local or paste the service_role key here.

NEXT_PUBLIC_SUPABASE_URL=PASTE-your-project-url-here
NEXT_PUBLIC_SUPABASE_ANON_KEY=PASTE-your-anon-key-here
